import joblib
from pathlib import Path

model.fit(X_train, y_train)

# --------------------------------------------------
# Save best model
# --------------------------------------------------

Path("outputs/models/random_forest/best_model").mkdir(
    parents=True,
    exist_ok=True
)

joblib.dump(
